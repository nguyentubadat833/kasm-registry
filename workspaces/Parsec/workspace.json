{
  "description": "Parsec remote desktop for gaming/low-latency.",
  "docker_registry": "https://index.docker.io/v1/",
  "image_src": "parsec.png",
  "run_config": {
    "hostname": "kasm",
    "shm_size": "1g" 
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "categories": ["Remote Desktop"],
  "friendly_name": "Parsec",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.18.x",
      "image": "shishkabob27/kasm-parsec:latest",
      "uncompressed_size_mb": 2170,
      "available_tags": ["latest"]
    }
  ]
}