{
  "description": "Parsec is a remote desktop and game streaming application that allows low-latency access to a remote machine.",
  "docker_registry": "https://index.docker.io/v1/",
  "image_src": "parsec.png",
  "run_config": {
    "hostname": "kasm"
  },
  "exec_config": {
    "go": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --go --url \"$KASM_URL\"'"
    },
    "assign": {
      "cmd": "bash -c '/dockerstartup/custom_startup.sh --assign --url \"$KASM_URL\"'"
    }
  },
  "categories": ["Remote Desktop", "Gaming", "Streaming"],
  "friendly_name": "Parsec",
  "architecture": ["amd64"],
  "compatibility": [
    {
      "version": "1.17.x",
      "image": "shishkabob27/kasm-parsec:latest",
      "uncompressed_size_mb": 2500,
      "available_tags": ["latest"]
    }
  ]
}
